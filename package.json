{
  "name": "learnova",
  "version": "1.0.0",
  "description": "AI-Powered Smart Student Engagement & Attendance Platform",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Premshaw23/Learnova.git"
  },
  "keywords": [
    "education",
    "ai",
    "attendance",
    "engagement",
    "gamification",
    "nextjs",
    "firebase"
