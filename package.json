  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --max-warnings 150",
    "format": "npx prettier@3.8.3 --write .",
    "format:check": "npx prettier@3.8.3 --check . || exit $(( $? > 1 ? $? : 0 ))",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "knip": "knip",
    "knip:deps": "knip --dependencies",
    "knip:files": "knip --files",
    "knip:exports": "knip --exports",
    "knip:fix": "knip --fix",
    "knip:check": "knip --no-progress",
    "quality": "pnpm run type-check && pnpm run lint && pnpm run knip",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
